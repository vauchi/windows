<UserControl
    x:Class="Vauchi.CoreUI.ScreenRenderer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Screen header: title + subtitle + progress -->
        <StackPanel x:Name="HeaderPanel" Grid.Row="0" Spacing="4" Margin="0,0,0,16">
            <TextBlock x:Name="ScreenTitle" Style="{StaticResource TitleTextBlockStyle}" />
            <TextBlock x:Name="ScreenSubtitle" Style="{StaticResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="Collapsed" />
            <ProgressBar x:Name="ProgressBar" Visibility="Collapsed" Minimum="0" />
            <TextBlock x:Name="ProgressLabel" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Visibility="Collapsed" />
        </StackPanel>

        <!-- Scrollable component area -->
        <ScrollViewer Grid.Row="1">
            <StackPanel x:Name="ComponentContainer" Spacing="16" />
        </ScrollViewer>

        <!-- Screen-level action buttons (pinned to bottom, outside scroll) -->
        <StackPanel x:Name="ActionButtonPanel" Grid.Row="2"
                    Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right" Margin="0,16,0,0" />
    </Grid>
</UserControl>
