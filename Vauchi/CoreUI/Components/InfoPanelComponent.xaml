<UserControl
    x:Class="Vauchi.CoreUI.Components.InfoPanelComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border CornerRadius="8" Padding="16"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
        <StackPanel x:Name="PanelContent" Spacing="8">
            <TextBlock x:Name="PanelTitle" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <StackPanel x:Name="ItemsContainer" Spacing="8" />
        </StackPanel>
    </Border>
</UserControl>
