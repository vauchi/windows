<UserControl
    x:Class="Vauchi.CoreUI.Components.EditableTextComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="4">
        <TextBlock x:Name="LabelText" Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <!-- Display mode -->
        <StackPanel x:Name="DisplayPanel" Orientation="Horizontal" Spacing="8">
            <TextBlock x:Name="DisplayValue" Style="{StaticResource BodyTextBlockStyle}"
                       VerticalAlignment="Center" />
            <Button x:Name="EditButton" Content="Edit" Padding="8,4" />
        </StackPanel>

        <!-- Edit mode -->
        <StackPanel x:Name="EditPanel" Visibility="Collapsed" Spacing="4">
            <TextBox x:Name="EditBox" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="SaveButton" Content="Save" Style="{StaticResource AccentButtonStyle}" />
                <Button x:Name="CancelButton" Content="Cancel" />
            </StackPanel>
        </StackPanel>

        <TextBlock x:Name="ValidationError" Foreground="Red" FontSize="12"
                   Visibility="Collapsed" TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
