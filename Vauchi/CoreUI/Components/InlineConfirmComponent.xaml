<UserControl
    x:Class="Vauchi.CoreUI.Components.InlineConfirmComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="8">
        <TextBlock x:Name="WarningText" Text="[InlineConfirm placeholder]"
                   TextWrapping="Wrap" />
        <StackPanel x:Name="ButtonPanel" Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right"
                    Visibility="Collapsed">
            <Button x:Name="CancelButton" Content="Cancel" />
            <Button x:Name="ConfirmButton" Content="Confirm" />
        </StackPanel>
    </StackPanel>
</UserControl>
