<UserControl
    x:Class="Vauchi.CoreUI.Components.CardPreviewComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8" Padding="16">
        <StackPanel Spacing="12">
            <Grid x:Name="AvatarArea" HorizontalAlignment="Center" Visibility="Collapsed">
                <Ellipse x:Name="AvatarCircle" Width="64" Height="64">
                    <Ellipse.Fill>
                        <ImageBrush x:Name="AvatarBrush" Stretch="UniformToFill" />
                    </Ellipse.Fill>
                </Ellipse>
            </Grid>
            <TextBlock x:Name="NameHeader"
                       FontSize="22"
                       FontWeight="SemiBold" />
            <ScrollViewer HorizontalScrollMode="Enabled"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollMode="Disabled">
                <StackPanel x:Name="GroupTabBar"
                            Orientation="Horizontal"
                            Spacing="4"
                            Visibility="Collapsed" />
            </ScrollViewer>
            <StackPanel x:Name="FieldsContainer" Spacing="6" />
        </StackPanel>
    </Border>
</UserControl>
