<UserControl
    x:Class="Vauchi.CoreUI.Components.PinInputComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="8">
        <TextBlock x:Name="PinLabel" Text="Enter PIN" Style="{StaticResource BodyTextBlockStyle}" />
        <StackPanel x:Name="DotContainer" Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Center" Margin="0,8,0,8" />
        <PasswordBox x:Name="PinBox" MaxLength="6" PlaceholderText=""
                     HorizontalAlignment="Center" Width="200" />
        <TextBlock x:Name="ValidationError" Foreground="Red" FontSize="12"
                   Visibility="Collapsed" TextWrapping="Wrap" HorizontalAlignment="Center" />
    </StackPanel>
</UserControl>
