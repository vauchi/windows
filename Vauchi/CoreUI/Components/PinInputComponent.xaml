<UserControl
    x:Class="Vauchi.CoreUI.Components.PinInputComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="8">
        <TextBlock x:Name="PinLabel" Text="Enter PIN"
                   Style="{StaticResource CaptionTextBlockStyle}" />
        <StackPanel x:Name="DigitContainer" Orientation="Horizontal" Spacing="8" />
        <TextBlock x:Name="ErrorText" Visibility="Collapsed"
                   Foreground="Red"
                   Style="{StaticResource CaptionTextBlockStyle}" />
    </StackPanel>
</UserControl>
