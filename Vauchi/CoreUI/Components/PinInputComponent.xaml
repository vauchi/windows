<UserControl
    x:Class="Vauchi.CoreUI.Components.PinInputComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="8">
        <TextBlock x:Name="PinLabel" Text="Enter PIN" />
        <PasswordBox x:Name="PinBox" MaxLength="6" PlaceholderText="------" />
    </StackPanel>
</UserControl>
