<UserControl
    x:Class="Vauchi.CoreUI.Components.StatusIndicatorComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Orientation="Horizontal" Spacing="8">
        <Ellipse x:Name="StatusDot" Width="12" Height="12" Fill="Gray" />
        <TextBlock x:Name="StatusText" Text="[StatusIndicator placeholder]" VerticalAlignment="Center" />
    </StackPanel>
</UserControl>
