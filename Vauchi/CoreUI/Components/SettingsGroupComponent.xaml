<UserControl
    x:Class="Vauchi.CoreUI.Components.SettingsGroupComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="8">
        <TextBlock x:Name="GroupLabel" FontWeight="SemiBold" FontSize="13" Opacity="0.7" />
        <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="8">
            <StackPanel x:Name="ItemsContainer" Spacing="0" />
        </Border>
    </StackPanel>
</UserControl>
