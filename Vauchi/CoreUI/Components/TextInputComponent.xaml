<UserControl
    x:Class="Vauchi.CoreUI.Components.TextInputComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="4">
        <TextBlock x:Name="InputLabel" Visibility="Collapsed"
                   Style="{StaticResource CaptionTextBlockStyle}" />
        <TextBox x:Name="InputBox" PlaceholderText=""
                 AutomationProperties.LabeledBy="{x:Bind InputLabel}" />
        <PasswordBox x:Name="PasswordInput" Visibility="Collapsed" PlaceholderText="" />
        <TextBlock x:Name="ErrorText" Visibility="Collapsed"
                   Foreground="Red"
                   Style="{StaticResource CaptionTextBlockStyle}" />
    </StackPanel>
</UserControl>
