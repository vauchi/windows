<UserControl
    x:Class="Vauchi.CoreUI.Components.TextInputComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="4">
        <TextBlock x:Name="LabelText" Style="{StaticResource BodyTextBlockStyle}" />
        <TextBox x:Name="InputBox" PlaceholderText="" />
        <PasswordBox x:Name="PasswordInput" Visibility="Collapsed" />
        <TextBlock x:Name="ValidationError" Foreground="Red" FontSize="12"
                   Visibility="Collapsed" TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
