<UserControl
    x:Class="Vauchi.CoreUI.Components.QrCodeComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel x:Name="QrContainer" HorizontalAlignment="Center" Spacing="8">
        <!-- Display mode: QR bitmap -->
        <Border x:Name="QrDisplayBorder" CornerRadius="8" Padding="16"
                Background="White" HorizontalAlignment="Center"
                Visibility="Collapsed">
            <Image x:Name="QrImage" Width="250" Height="250"
                   Stretch="NearestNeighbor" />
        </Border>

        <!-- Scan mode: camera preview -->
        <Border x:Name="ScanBorder" CornerRadius="8"
                Background="Black" HorizontalAlignment="Center"
                Width="320" Height="240" Visibility="Collapsed">
            <CaptureElement x:Name="CameraPreview" Stretch="UniformToFill" />
        </Border>

        <TextBlock x:Name="QrLabel" Style="{StaticResource CaptionTextBlockStyle}"
                   HorizontalAlignment="Center" Visibility="Collapsed" />
        <TextBlock x:Name="ScanStatus" Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   HorizontalAlignment="Center" Visibility="Collapsed" TextWrapping="Wrap" />
        <Button x:Name="ScanButton" Content="Scan QR Code"
                HorizontalAlignment="Center" Visibility="Collapsed" />
    </StackPanel>
</UserControl>
