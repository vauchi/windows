<UserControl
    x:Class="Vauchi.CoreUI.Components.QrCodeComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel x:Name="QrContainer" Spacing="8"
                HorizontalAlignment="Center" VerticalAlignment="Center">
        <!-- Display mode: bordered monospace text -->
        <Border x:Name="DisplayBorder" BorderBrush="Gray" BorderThickness="1"
                Padding="16" Visibility="Collapsed">
            <TextBlock x:Name="QrDataText" FontFamily="Consolas"
                       FontSize="10" TextWrapping="Wrap" MaxWidth="400"
                       IsTextSelectionEnabled="True" />
        </Border>
        <!-- Scan mode: paste + submit -->
        <StackPanel x:Name="ScanPanel" Spacing="4" Visibility="Collapsed">
            <TextBlock Text="Paste QR code data:" />
            <TextBox x:Name="ScanInput" PlaceholderText="Paste scanned QR data here..."
                     AcceptsReturn="False" />
            <Button x:Name="ScanSubmitButton" Content="Submit" />
        </StackPanel>
    </StackPanel>
</UserControl>
