<UserControl
    x:Class="Vauchi.CoreUI.Components.ConfirmationDialogComponent"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="8">
        <TextBlock x:Name="DialogTitle" FontWeight="SemiBold" FontSize="16" Visibility="Collapsed" />
        <TextBlock x:Name="DialogMessage" Text="" TextWrapping="Wrap" />
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Cancel" />
            <Button x:Name="ConfirmButton" Content="Confirm" />
        </StackPanel>
    </StackPanel>
</UserControl>
