<Window
    x:Class="Vauchi.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:coreui="using:Vauchi.CoreUI"
    Title="Vauchi"
    Closed="OnClosed">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Menu bar -->
        <MenuBar Grid.Row="0">
            <MenuBarItem Title="File">
                <MenuFlyoutItem Text="Quit" Click="OnQuitClicked">
                    <MenuFlyoutItem.KeyboardAccelerators>
                        <KeyboardAccelerator Modifiers="Control" Key="Q" />
                    </MenuFlyoutItem.KeyboardAccelerators>
                </MenuFlyoutItem>
            </MenuBarItem>
            <MenuBarItem Title="Help">
                <MenuFlyoutItem Text="About Vauchi" Click="OnAboutClicked" />
            </MenuBarItem>
        </MenuBar>

        <!-- Sidebar + Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListView x:Name="Sidebar"
                      Grid.Column="0"
                      SelectionMode="Single"
                      SelectionChanged="OnSidebarSelectionChanged"
                      Padding="4" />

            <coreui:ScreenRenderer x:Name="Renderer" Grid.Column="1" />
        </Grid>
    </Grid>
</Window>
